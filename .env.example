# Gemini (Google AI Studio)
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# Supabase (público — exposto no frontend)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# Supabase (servidor — NUNCA expor no frontend)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_AQUI

# Zoho SMTP (e-mail de notificações)
ZOHO_SMTP_USER=seu@email.com
ZOHO_SMTP_PASS=SUA_SENHA_SMTP_AQUI
NOTIFICATION_EMAIL=destino@email.com

# Google reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=SUA_SITE_KEY_AQUI
RECAPTCHA_SECRET_KEY=SUA_SECRET_KEY_AQUI
