        "parameters": {
          "jsCode": "const todosOsDias = $input.all().map(item => item.json);\nconst resumo = todosOsDias\n  .filter(dia => dia.data)\n  .map(dia => ({\n    data: dia.data,\n    horarios: dia.slots_disponiveis || []\n  }));\nreturn [{\n  json: {\n    dias_disponiveis: resumo\n  }\n}];"
        },
