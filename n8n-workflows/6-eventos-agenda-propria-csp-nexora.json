    {
      "parameters": {
        "jsCode": "const inicioReuniaoOriginal = $('When Executed by Another Workflow').first().json.inicio_reuniao;\nconst idAgendamento = $('When Executed by Another Workflow').first().json.id_agendamento;\n\nconst dataObjOriginal = new Date(inicioReuniaoOriginal);\nconst mes = String(dataObjOriginal.getMonth() + 1).padStart(2, '0');\nconst dia = String(dataObjOriginal.getDate()).padStart(2, '0');\nconst hora = String(dataObjOriginal.getHours()).padStart(2, '0');\nconst minuto = String(dataObjOriginal.getMinutes()).padStart(2, '0');\n\nconst hoje = new Date();\nconst anoAtual = hoje.getFullYear();\n\nlet dataCorrigida = new Date(`${anoAtual}-${mes}-${dia}T${hora}:${minuto}:00`);\n\nconst hojeSemHora = new Date(hoje.getFullYear(), hoje.getMonth(), hoje.getDate());\nconst dataCorrigidaSemHora = new Date(dataCorrigida.getFullYear(), dataCorrigida.getMonth(), dataCorrigida.getDate());\n\nif (dataCorrigidaSemHora < hojeSemHora) {\n  dataCorrigida = new Date(`${anoAtual + 1}-${mes}-${dia}T${hora}:${minuto}:00`);\n}\n\nconst anoFinal = dataCorrigida.getFullYear();\nconst data = `${anoFinal}-${mes}-${dia}`;\nconst horaFinal = `${hora}:${minuto}`;\n\nreturn [{\n  json: {\n    id_agendamento: idAgendamento,\n    data,\n    hora: horaFinal\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1008,
        208
      ],
      "id": "5ed21bdc-bc81-4a0e-9105-0eb987670b4b",
      "name": "SepararDataHoraReagendamento"
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=https://visjhadwewvxnqwekpdk.supabase.co/functions/v1/agendamentos-id/{{ $json.id_agendamento }}",
