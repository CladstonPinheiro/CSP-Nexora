    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json;\nconst dataConsultaInput = inputData.data_consulta;\n\nfunction formatarData(d) {\n  const ano = d.getFullYear();\n  const mes = String(d.getMonth() + 1).padStart(2, '0');\n  const dia = String(d.getDate()).padStart(2, '0');\n  return `${ano}-${mes}-${dia}`;\n}\n\nfunction hojeSaoPaulo() {\n  const partes = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Sao_Paulo' })\n    .formatToParts(new Date());\n  const ano = partes.find(p => p.type === 'year').value;\n  const mes = partes.find(p => p.type === 'month').value;\n  const dia = partes.find(p => p.type === 'day').value;\n  return new Date(`${ano}-${mes}-${dia}T00:00:00`);\n}\n\nif (dataConsultaInput) {\n  const [, mes, dia] = dataConsultaInput.split('-');\n  const hoje = hojeSaoPaulo();\n  const anoAtual = hoje.getFullYear();\n  let dataCorrigida = new Date(`${anoAtual}-${mes}-${dia}T00:00:00`);\n  if (dataCorrigida < hoje) {\n    dataCorrigida = new Date(`${anoAtual + 1}-${mes}-${dia}T00:00:00`);\n  }\n  return [{ json: { ...inputData, data_consulta: formatarData(dataCorrigida) } }];\n}\n\nconst diasResultado = [];\nconst hoje = hojeSaoPaulo();\nlet offset = 1;\nwhile (diasResultado.length < 3) {\n  const candidata = new Date(hoje);\n  candidata.setDate(hoje.getDate() + offset);\n  const diaSemana = candidata.getDay(); // 0 = domingo, 6 = sábado\n  if (diaSemana !== 0 && diaSemana !== 6) {\n    diasResultado.push({ json: { ...inputData, data_consulta: formatarData(candidata) } });\n  }\n  offset++;\n}\nreturn diasResultado;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        -80
      ],
      "id": "7fd12545-178a-4af6-9869-0fcf58c8a9d9",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const inicioReuniaoOriginal = $('When Executed by Another Workflow').first().json.inicio_reuniao;\nconst assunto = $('When Executed by Another Workflow').first().json.assunto;\n\nconst dataObjOriginal = new Date(inicioReuniaoOriginal);\nconst mes = String(dataObjOriginal.getMonth() + 1).padStart(2, '0');\nconst dia = String(dataObjOriginal.getDate()).padStart(2, '0');\nconst hora = String(dataObjOriginal.getHours()).padStart(2, '0');\nconst minuto = String(dataObjOriginal.getMinutes()).padStart(2, '0');\n\nconst hoje = new Date();\nconst anoAtual = hoje.getFullYear();\n\nlet dataCorrigida = new Date(`${anoAtual}-${mes}-${dia}T${hora}:${minuto}:00`);\n\nconst hojeSemHora = new Date(hoje.getFullYear(), hoje.getMonth(), hoje.getDate());\nconst dataCorrigidaSemHora = new Date(dataCorrigida.getFullYear(), dataCorrigida.getMonth(), dataCorrigida.getDate());\n\nif (dataCorrigidaSemHora < hojeSemHora) {\n  dataCorrigida = new Date(`${anoAtual + 1}-${mes}-${dia}T${hora}:${minuto}:00`);\n}\n\nconst anoFinal = dataCorrigida.getFullYear();\nconst data = `${anoFinal}-${mes}-${dia}`;\nconst horaFinal = `${hora}:${minuto}`;\n\nreturn [{\n  json: {\n    lead_id: $('BuscarLeadId').first().json.id,\n    data,\n    hora: horaFinal,\n    assunto: assunto || null,\n    observacoes: null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1024,
